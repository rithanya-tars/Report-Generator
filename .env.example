# ──────────────────────────────────────────────────────────────────────────────
# Tars Report Generator — Environment Config
# Copy this file to .env and fill in your values
# DO NOT commit .env to GitHub!
# ──────────────────────────────────────────────────────────────────────────────

# Your Anthropic API key (get it from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Path to your TarsReports folder on your machine
# Mac example:     TARS_DATA_PATH=/Users/yourname/TarsReports
# Windows example: TARS_DATA_PATH=C:\Users\yourname\TarsReports
# Linux example:   TARS_DATA_PATH=/home/yourname/TarsReports
TARS_DATA_PATH=/Users/yourname/TarsReports
